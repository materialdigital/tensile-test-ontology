PREFIX pmdco: <https://w3id.org/pmd/co/>
PREFIX obo:   <http://purl.obolibrary.org/obo/>

SELECT DISTINCT ?material_tested
WHERE {
  # simpler: just take any identifier that denotes a material node
  ?id a pmdco:PMD_0000017 ;
      obo:IAO_0000219 ?mat ;
      pmdco:PMD_0060000 ?vs .

  # value literal
  ?vs pmdco:PMD_0000006 ?material_tested .
  FILTER(isLiteral(?material_tested))

  # restrict to the material identifier you created ("Werkstoff")
  FILTER(CONTAINS(STR(?id), "_material_identifier"))
}
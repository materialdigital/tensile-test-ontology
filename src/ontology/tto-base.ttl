                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "Dehngeschwindigkeit"@de ,
                                                  "strain rate"@en ;
                                       rdfs:seeAlso <https://w3id.org/pmd/tto/StrainRate> ;

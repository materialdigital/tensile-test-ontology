AnnotationAssertion(rdfs:label co:PMD_0001023 "x-ray mapping device"@en)
AnnotationAssertion(skos:definition co:PMD_0001023 "A device used for mapping the spatial distribution of elements or compounds within a material using X-ray fluorescence or diffraction techniques."@en)
AnnotationAssertion(skos:definition co:PMD_0001023 "Ein Gerät, das zur Kartierung der räumlichen Verteilung von Elementen oder Verbindungen innerhalb eines Materials mithilfe von Röntgenfluoreszenz- oder -beugungstechniken verwendet wird."@de)
SubClassOf(co:PMD_0001023 co:PMD_0000602)


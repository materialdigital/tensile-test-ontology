AnnotationAssertion(rdfs:label co:PMD_0000503 "ASTM grainsize"@en)
AnnotationAssertion(skos:definition co:PMD_0000503 "The ASTM grain size is a quality that is measured through a process that follows the ASTM standard."@en)

# Class: obo:OBI_0001931 (scalar value specification)

AnnotationAssertion(obo:IAO_0000115 obo:OBI_0001931 "A value specification that consists of two parts: a numeral and a unit label"@en)
AnnotationAssertion(rdfs:label obo:OBI_0001931 "scalar value specification")

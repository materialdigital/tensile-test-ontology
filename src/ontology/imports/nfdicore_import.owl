AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/IAO_0000235> "denoted by"@en)
SubObjectPropertyOf(<http://purl.obolibrary.org/obo/IAO_0000235> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000226>)

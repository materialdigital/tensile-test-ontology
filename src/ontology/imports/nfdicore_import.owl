AnnotationAssertion(rdfs:comment <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001085> "Privatdozent with Habilitation (higher academic qualification in Germany)")
AnnotationAssertion(rdfs:label <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001085> "PD. Dr. habil."@en)
ClassAssertion(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001040> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001085>)

# Individual: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001086> (planning status)

AnnotationAssertion(rdfs:comment <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001086> "Planning Status is a status specification that indicates an entity, process, or project is in a preparatory or strategic development phase before execution.")
AnnotationAssertion(rdfs:label <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001086> "planning status"@en)
ClassAssertion(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001056> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001086>)


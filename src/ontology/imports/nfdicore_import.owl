EquivalentClasses(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000102> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000004> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000087> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229>)))

AnnotationAssertion(rdfs:comment <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001087> "Professor (academic title for a senior faculty member).")
AnnotationAssertion(rdfs:label <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001087> "Prof."@en)
ClassAssertion(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001040> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001087>)


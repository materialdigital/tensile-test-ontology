AnnotationAssertion(rdfs:comment <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001084> "Privatdozent (Dr. with habilitation, qualified to teach at a university)")
AnnotationAssertion(rdfs:label <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001084> "PD. Dr."@en)
ClassAssertion(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001040> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001084>)

